classDiagram
    class Owner {
        +String name
        +int time_available
        +List~Pet~ pets
        +List~Task~ tasks
        +add_pet(pet: Pet)
        +remove_pet(pet: Pet)
        +add_task(task: Task)
        +remove_task(task: Task)
    }

    class Pet {
        +String name
        +String animal_type
    }

    class Task {
        +String task_type
        +int duration
        +int priority
        +Pet pet
    }

    class Scheduler {
        +generate_plan(tasks: List~Task~, time_available: int) List~Task~
        +explain_plan(plan: List~Task~) String
    }

    Owner "one" --> "many" Pet : has
    Owner "one" --> "many" Task : has
    Task "many" --> "one" Pet : for
    Owner ..> Scheduler : uses